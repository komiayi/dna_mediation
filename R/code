#' @title Estimation des effets direct et indirect d'un médiateur
#'
#' @description
#' Cette fonction estime les effets direct et indirect du médiateur d'intérêt
#' dans un cadre de médiation causale, en tenant compte d'une structure potentiellement
#' corrélée entre deux médiateurs. Elle utilise des modèles linéaires pour les médiateurs
#' et la variable de réponse, et gère différentes spécifications de la structure
#' de corrélation entre les médiateurs.
#'
#' @param data Un `data.frame` contenant toutes les variables nécessaires à l'analyse.
#' @param treat Nom de la variable de traitement (exposition) comme une chaîne de caractères.
#'   Doit être une variable binaire (0/1).
#' @param outcome Nom de la variable de réponse comme une chaîne de caractères.
#' @param mediators Vecteur de noms des variables médiatrices (par exemple, `c("M1", "M2")`).
#'   Le premier élément est considéré comme le médiateur d'intérêt (`intmed`).
#' @param intmed_cov Vecteur de noms des covariables à inclure dans le modèle du médiateur
#'   d'intérêt. Peut être `NULL`.
#' @param sed_cov Vecteur de noms des covariables à inclure dans le modèle du second médiateur.
#'   Peut être `NULL`.
#' @param out_cov Vecteur de noms des covariables à inclure dans le modèle de réponse.
#'   Peut être `NULL`.
#' @param inter_treat_cov Logique : Si `TRUE`, des termes d'interaction entre le traitement
#'   (`treat`) et les covariables (`intmed_cov`, `sed_cov`) sont inclus dans les modèles des médiateurs.
#'   Par défaut : `FALSE`.
#' @param inter Logique : Si `TRUE`, des termes d'interaction entre l'exposition (`treat`)
#'   et les médiateurs (`mediators`) sont inclus dans le modèle de réponse. Par défaut : `FALSE`.
#' @param formula_outcome_custom Formule personnalisée pour le modèle de réponse, utilisée
#'   uniquement si `inter = TRUE`. Elle permet de spécifier explicitement les interactions
#'   entre l'exposition et les médiateurs. Si non spécifiée, une formule par défaut
#'   incluant `treat`, `mediators`, `out_cov`, et les interactions `treat:M1`, `treat:M2`, `M1:M2`,
#'   et `treat:M1:M2` est générée.
#' @param cor_structure Entier : `1` pour une corrélation constante entre les résidus des
#'   médiateurs (`rho_00 = rho_11`), `3` pour des corrélations distinctes en fonction
#'   du niveau de traitement (`rho_00` et `rho_11` sont estimées séparément).
#'   Par défaut : `1`.
#' @param rho_fixed Numérique : Une valeur de corrélation fixe à imposer entre les médiateurs
#'   dans le cas `cor_structure = 3` pour un scénario "fixe". Par défaut : `0.5`.
#' @param use_optim_for_mediators Logique : Si `TRUE`, utilise l'optimisation numérique (via `optim`)
#'   pour estimer les paramètres des modèles de médiateurs et leurs corrélations.
#'   Si `FALSE` (par défaut), utilise des expressions analytiques directes via `lm`
#'   pour ces estimations.
#'
#' @return Une liste contenant les éléments suivants :
#' \describe{
#'   \item{direct_effects}{Un `data.frame` des estimations des effets directs moyens.}
#'   \item{indirect_effects}{Un `data.frame` des estimations des effets indirects moyens.}
#'   \item{coef_mediator1}{Coefficients estimés du modèle du médiateur d'intérêt.}
#'   \item{coef_mediator2}{Coefficients estimés du modèle du second médiateur.}
#'   \item{coef_outcome}{Coefficients estimés du modèle de réponse.}
#'   \item{cor_parameters}{Paramètres de corrélation estimés entre les deux médiateurs (écarts-types des résidus et corrélations).}
#'   \item{rho01_estimates}{Estimations des corrélations non observées entre les valeurs contrefactuelles
#'     du médiateur d'intérêt sous exposition $A=0$ et du second médiateur sous exposition $A=1$.}
#'   \item{rho10_estimates}{Estimations des corrélations non observées entre les valeurs contrefactuelles
#'     du médiateur d'intérêt sous exposition $A=1$ et du second médiateur sous exposition $A=0$.}
#'   \item{rho_root_method}{Estimations des corrélations et moyennes/fixes utilisées pour la méthode par racine.}
#' }
#'
#' @examples
#' \dontrun{
#' # Exemple hypothétique avec des données simulées
#' set.seed(123)
#' N <- 100
#' mydata <- data.frame(
#'   X = rbinom(N, 1, 0.5), # Traitement binaire
#'   C1 = rnorm(N),        # Covariable
#'   C2 = rnorm(N),        # Autre covariable
#'   M1 = 0.5 * rnorm(N) + 0.3 * rbinom(N, 1, 0.5) + 0.2 * rnorm(N, mean = 2, sd = 0.5),
#'   M2 = 0.6 * rnorm(N) + 0.4 * rbinom(N, 1, 0.5) + 0.1 * rnorm(N, mean = 1, sd = 0.3)
#' )
#' mydata$Y <- 0.5 + 0.2 * mydata$X + 0.4 * mydata$M1 + 0.3 * mydata$M2 +
#'             0.1 * mydata$X * mydata$M1 + 0.05 * mydata$C1 + rnorm(N, sd = 0.5)
#'
#' lm_formula_str <- paste(c('X', 'M1','M2', 'covariate', paste(c('M1','M2'), collapse ="*")), collapse ="+")
#' lmfor <- as.formula(paste('Y',"~", lm_formula_str))
#'
#'
#' # Exécution avec expressions analytiques (lm) - par défaut
#' result_lm <- mediate_effects(
#'   data = mydata,
#'   treat = "X",
#'   outcome = "Y",
#'   mediators = c("M1", "M2"),
#'   intmed_cov = "C1",
#'   sed_cov = "C2",
#'   inter = FALSE,
#'   cor_structure = 1,
#'   formula_outcome_custom = lmfor,
#'   use_optim_for_mediators = FALSE
#' )
#' print(result_lm$direct_effects)
#' print(result_lm$indirect_effects)
#'
#' # Exécution avec optimisation numérique (optim) pour les médiateurs
#' result_optim <- mediate_effects(
#'   data = mydata,
#'   treat = "X",
#'   outcome = "Y",
#'   mediators = c("M1", "M2"),
#'   intmed_cov = "C1",
#'   sed_cov = "C2",
#'   inter = TRUE,
#'   cor_structure = 3,
#'   formula_outcome_custom = lmfor,
#'   use_optim_for_mediators = TRUE
#' )
#' print(result_optim$direct_effects)
#' print(result_optim$indirect_effects)
#' }
#'
#' @importFrom mvtnorm dmvnorm
#' @importFrom stats as.formula coef lm model.frame model.matrix model.response optim sd cor
#' @export
mediate_effects <- function(data, treat, outcome, mediators, intmed_cov = NULL,
                            sed_cov = NULL, out_cov = NULL, inter_treat_cov = FALSE,
                            inter = FALSE, formula_outcome_custom = NULL,
                            cor_structure = 1, rho_fixed = 0.5,
                            use_optim_for_mediators = FALSE) {
  
  # --- 1. Validation des entrées ---
  if (!is.data.frame(data)) {
    stop("Le paramètre 'data' doit être un data.frame.")
  }
  required_vars <- c(treat, outcome, mediators, intmed_cov, sed_cov, out_cov)
  missing_vars <- setdiff(required_vars, names(data))
  if (length(missing_vars) > 0) {
    stop(paste("Les variables suivantes sont manquantes dans le jeu de données:",
               paste(missing_vars, collapse = ", ")))
  }
  if (length(mediators) != 2) {
    stop("Le vecteur 'mediators' doit contenir exactement deux noms de variables.")
  }
  if (!is.numeric(data[[treat]]) || !all(unique(data[[treat]]) %in% c(0, 1))) {
    stop("La variable de traitement 'treat' doit être numérique et binaire (0 ou 1).")
  }
  if (!cor_structure %in% c(1, 3)) {
    stop("Le paramètre 'cor_structure' doit être 1 ou 3.")
  }
  if (cor_structure == 3 && (!is.numeric(rho_fixed) || length(rho_fixed) != 1 || rho_fixed < -1 || rho_fixed > 1)) {
    warning("Le paramètre 'rho_fixed' doit être une valeur numérique entre -1 et 1 pour 'cor_structure = 3'. Utilisation de la valeur par défaut (0.5).")
    rho_fixed <- 0.5
  }
  if (!is.logical(use_optim_for_mediators)) {
    stop("Le paramètre 'use_optim_for_mediators' doit être TRUE ou FALSE.")
  }
  
  # Définition du médiateur d'intérêt et du second médiateur
  intmed <- mediators[1]
  sedmed <- mediators[2]
  
  # --- 2. Génération des formules de modèle ---
  model_formulas <- generate_model_formulas(
    treat = treat,
    mediators = mediators,
    intmed = intmed,
    sedmed = sedmed,
    outcome = outcome,
    intmed_cov = intmed_cov,
    sed_cov = sed_cov,
    out_cov = out_cov,
    inter_treat_cov = inter_treat_cov,
    inter = inter,
    formula_outcome_custom = formula_outcome_custom
  )
  
  
  # --- 3. Estimation des paramètres des modèles ---
  
  # Estimation du modèle de la variable de réponse (toujours via lm)
  fit_outcome <- lm(model_formulas$formula_outcome, data = data)
  coef_outcome <- coef(fit_outcome)
  sd_outcome_residuals <- sd(residuals(fit_outcome))
  
  # Ajustement des coefficients de l'outcome pour inclure les interactions manquantes
  if (inter) {
    default_interaction_names <- c(
      paste0(treat, ":", mediators[1]),
      paste0(treat, ":", mediators[2]),
      paste0(mediators[1], ":", mediators[2]),
      paste0(treat, ":", mediators[1], ":", mediators[2])
    )
    missing_inter_coefs <- setdiff(default_interaction_names, names(coef_outcome))
    if (length(missing_inter_coefs) > 0) {
      new_coefs <- setNames(rep(0, length(missing_inter_coefs)), missing_inter_coefs)
      coef_outcome <- c(coef_outcome, new_coefs)
    }
  }
  coef_outcome <- c(coef_outcome, sd = sd_outcome_residuals)
  
  # Estimation des paramètres des modèles de médiateurs et de leurs corrélations
  if (use_optim_for_mediators) {
    # Utilisation de optim pour les médiateurs (avec initialisation par lm)
    initial_lm_m1 <- lm(model_formulas$formula_m1, data = data)
    initial_lm_m2 <- lm(model_formulas$formula_m2, data = data)
    
    # Initialisation des paramètres de corrélation pour optim
    initial_res_m1 <- residuals(initial_lm_m1)
    initial_res_m2 <- residuals(initial_lm_m2)
    
    initial_sigma1 <- sd(initial_res_m1)
    initial_sigma2 <- sd(initial_res_m2)
    initial_rho <- cor(initial_res_m1, initial_res_m2)
    
    if (cor_structure == 1) {
      initial_cor_params <- c(initial_sigma1, initial_sigma2, initial_rho)
    } else { # cor_structure == 3
      res_m1_t1 <- initial_res_m1[data[[treat]] == 1]
      res_m2_t1 <- initial_res_m2[data[[treat]] == 1]
      res_m1_t0 <- initial_res_m1[data[[treat]] == 0]
      res_m2_t0 <- initial_res_m2[data[[treat]] == 0]
      
      initial_sigma1_t1 <- sd(res_m1_t1)
      initial_sigma1_t0 <- sd(res_m1_t0)
      initial_sigma2_t1 <- sd(res_m2_t1)
      initial_sigma2_t0 <- sd(res_m2_t0)
      
      initial_rho_t1 <- cor(res_m1_t1, res_m2_t1)
      initial_rho_t0 <- cor(res_m1_t0, res_m2_t0)
      initial_cor_params <- c(initial_sigma1_t1, initial_sigma1_t0,
                              initial_sigma2_t1, initial_sigma2_t0,
                              initial_rho_t1, initial_rho_t0)
    }
    
    # Combinaison des paramètres initiaux
    initial_params_optim <- c(coef(initial_lm_m1), coef(initial_lm_m2), initial_cor_params)
    
    # Définition de q1 et q2 pour Loglik.med
    q1 <- length(coef(initial_lm_m1))
    q2 <- length(coef(initial_lm_m2))
    
    # Appel à la fonction optimisée des paramètres des médiateurs
    params_mediators_optim <- estimate_mediator_params_optim(
      par = initial_params_optim,
      q1 = q1,
      q2 = q2,
      treat = treat,
      mediators = mediators,
      formula_m1 = model_formulas$formula_m1,
      formula_m2 = model_formulas$formula_m2,
      data = data,
      cor_structure = cor_structure
    )
    
    # Récupérer les noms des coefficients des modèles lm initiaux pour les assigner
    initial_lm_m1 <- lm(model_formulas$formula_m1, data = data)
    initial_lm_m2 <- lm(model_formulas$formula_m2, data = data)
    
    coef_m1 <- params_mediators_optim$Cint
    names(coef_m1) <- names(coef(initial_lm_m1)) # <--- AJOUTER CETTE LIGNE
    
    coef_m2 <- params_mediators_optim$Csed
    names(coef_m2) <- names(coef(initial_lm_m2)) # <--- AJOUTER CETTE LIGNE
    
    cor_params_est <- params_mediators_optim$Ccor
    
  } else {
    # Utilisation d'expressions analytiques (lm) pour les médiateurs
    fit_m1 <- lm(model_formulas$formula_m1, data = data)
    coef_m1 <- coef(fit_m1)
    residuals_m1 <- residuals(fit_m1)
    
    fit_m2 <- lm(model_formulas$formula_m2, data = data)
    coef_m2 <- coef(fit_m2)
    residuals_m2 <- residuals(fit_m2)
    
    cor_params_est <- estimate_correlation_parameters_analytic(
      residuals_m1 = residuals_m1,
      residuals_m2 = residuals_m2,
      data = data,
      treat = treat,
      cor_structure = cor_structure
    )$cor_coefs
  }
  
  # --- 4. Calcul des corrélations r01 et r10 ---
  r_estimates <- calculate_r01_r10(
    cor_params = cor_params_est,
    cor_structure = cor_structure,
    rho_fixed = rho_fixed
  )
  
  # --- 5. Préparation des coefficients pour le calcul des effets ---
  alpha_df_list <- list()
  alpha_df_list[[mediators[1]]] <- data.frame(
    name = names(coef_m1),
    value = as.numeric(coef_m1),
    row.names = names(coef_m1)
  )
  alpha_df_list[[mediators[2]]] <- data.frame(
    name = names(coef_m2),
    value = as.numeric(coef_m2),
    row.names = names(coef_m2)
  )
  
  beta_df <- data.frame(
    name = names(coef_outcome),
    value = as.numeric(coef_outcome),
    row.names = names(coef_outcome)
  )
  
  # --- 6. Calcul des effets directs et indirects ---
  effects_result <- calculate_conditional_effects(
    alpha = alpha_df_list,
    beta = beta_df,
    treat = treat,
    mediators = mediators,
    intmed_cov = intmed_cov,
    sed_cov = sed_cov,
    inter = inter,
    cor_params_vec = cor_params_est, # Passer le vecteur des coefficients de corrélation bruts
    rho_values = r_estimates$r01, # Passer les r01 calculés
    data = data,
    cor_structure = cor_structure
  )
  
  # --- 7. Préparation des noms de colonnes pour les résultats ---
  if (cor_structure == 3) {
    #effect_names <- c(paste0("racine", 1:length(r_estimates$r01[!is.na(r_estimates$r01)])), "moyen", "fixe")
    effect_names <- c(paste0("racine", 1:4), "moyen", "fixe")
  } else {
    effect_names <- "Estimation"
  }
  
  DE_results <- as.data.frame(t(effects_result$DE_calculated))
  colnames(DE_results) <- paste0("DE_", effect_names)
  
  IE_results <- as.data.frame(t(effects_result$IE_calculated))
  colnames(IE_results) <- paste0("IE_", effect_names)
  
  # Noms pour les coefficients de corrélation
  if (cor_structure == 3) {
    cor_coef_names <- c("sd_M1_T1", "sd_M1_T0", "sd_M2_T1", "sd_M2_T0", "rho_T1", "rho_T0")
  } else {
    cor_coef_names <- c("sd_M1", "sd_M2", "rho_M1M2")
  }
  names(cor_params_est) <- cor_coef_names
  
  # Noms pour rho01 et rho10
  rho01_names <- paste0("rho01_", effect_names)
  rho10_names <- paste0("rho10_", effect_names)
  
  rho01_df <- as.data.frame(t(r_estimates$r01))
  colnames(rho01_df) <- rho01_names
  
  rho10_df <- as.data.frame(t(r_estimates$r10))
  colnames(rho10_df) <- rho10_names
  
  rho_racine_df <- NULL
  if (cor_structure == 3) {
    # Filtrer les NA de rho_root_values avant de nommer pour éviter les colonnes NA
    #valid_rho_root_values <- r_estimates$rho_root_values[!is.na(r_estimates$rho_root_values)]
    valid_rho_root_values <- r_estimates$rho_root_values
    rho_racine_df <- as.data.frame(t(valid_rho_root_values))
    colnames(rho_racine_df) <- paste0(c(paste0("racine", 1:4),'moyen','fixe'))
  }
  
  return(list(
    direct_effects = DE_results,
    indirect_effects = IE_results,
    coef_mediator1 = as.data.frame(t(coef_m1)),
    coef_mediator2 = as.data.frame(t(coef_m2)),
    coef_outcome = as.data.frame(t(coef_outcome)),
    cor_parameters = as.data.frame(t(cor_params_est)),
    rho01_estimates = rho01_df,
    rho10_estimates = rho10_df,
    rho_root_method = rho_racine_df
  ))
}

