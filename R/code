#' @title Calcule les corrélations r01 et r10
#'
#' @description
#' Estime les corrélations croisées $r_{01}$ et $r_{10}$ entre les médiateurs
#' sous différentes conditions d'exposition contrefactuelles.
#'
#' @param cor_params Numeric vector des paramètres de corrélation estimés
#'   (écarts-types et corrélations brutes).
#' @param cor_structure Entier : 1 (corrélation constante) ou 3 (corrélation non constante).
#' @param rho_fixed Corrélation fixe à utiliser si `cor_structure = 3` et pas de solution valide.
#'
#' @return Une liste avec les vecteurs `r01`, `r10` et `rho_root_values` (pour `cor_structure = 3`).
#' @keywords internal
calculate_r01_r10 <- function(cor_params, cor_structure, rho_fixed = 0.5) {
  r01_out <- NA
  r10_out <- NA
  rho_root_values_out <- NULL
  
  if (cor_structure == 3) {
    # Paramètres pour le cas cor_structure = 3
    # cor_params dans varcovarEstimes (s11,s10,s21,s20,rho11,rho00)
    s11 <- cor_params[1] # sigma_M1_T1
    s10 <- cor_params[2] # sigma_M1_T0
    s21 <- cor_params[3] # sigma_M2_T1
    s20 <- cor_params[4] # sigma_M2_T0
    rho11 <- cor_params[5] # rho_M1M2_T1
    rho00 <- cor_params[6] # rho_M1M2_T0
    
    # Calcul des termes de l'équation polynomiale du code original
    Delta1_orig <- -( (s11 * s21 * rho11)^2 + (s10 * s20 * rho00)^2 ) +
      (s11^2 - s10^2) * (s21^2 - s20^2)
    Delt_orig <- (Delta1_orig)^2 - 4 * (s11 * s10 * s21 * s20 * rho11 * rho00)^2
    
    if (Delt_orig < 0 || is.na(Delt_orig)) {
      # Si pas de solution réelle, utiliser la moyenne et la valeur fixe
      r01_out <- c(NA, (rho11 + rho00) / 2, rho_fixed)
      r10_out <- c(NA, (rho11 + rho00) / 2, rho_fixed)
      warning("Pas de solution réelle pour les racines de rho. Les estimations r01/r10 des racines sont NA.")
    } else {
      # Solutions pour (r01)^2 basé sur le code original
      # L'expression prod(cor_coefs[c(2, 3)])^2 est (s10 * s21)^2
      denominator_val <- (s10 * s21)^2
      if (denominator_val == 0) {
        warning("Le dénominateur pour le calcul des racines de rho est zéro. Les estimations r01/r10 des racines sont NA.")
        r01_out <- NA
      } else {
        potential_Delta3_val <- 0.5 * (-Delta1_orig + c(sqrt(Delt_orig), -sqrt(Delt_orig))) / denominator_val
        potential_Delta3_val <- potential_Delta3_val[!is.na(potential_Delta3_val) & potential_Delta3_val >= 0]
        
        if (length(potential_Delta3_val) == 0) {
          r01_solutions <- NA
        } else {
          r01_solutions <- c(sqrt(potential_Delta3_val), -sqrt(potential_Delta3_val))
          # Filtrer pour r01 entre -1 et 1
          r01_solutions <- r01_solutions[!is.na(r01_solutions) & abs(r01_solutions) <= 1]
        }
        
        if (length(r01_solutions) == 0) {
          r01_out <- NA
          r10_out <- NA
        } else {
          r01_out <- r01_solutions
          r10_out <- (rho11 * rho00) / r01_out
          # Filtrer pour r10 entre -1 et 1
          valid_indices <- which(!is.na(r10_out) & abs(r10_out) <= 1)
          #r01_out <- r01_out[valid_indices]
          #r10_out <- r10_out[valid_indices]
        }
      }
    }
    
    # Ajout des valeurs 'moyen' et 'fixe' pour r01 et r10
    # S'assurer que r01_out n'est pas NA avant de concaténer
    #r01_final <- r01_out[!is.na(r01_out)]
    #r10_final <- r10_out[!is.na(r10_out)]
    
    r01_final <- c(r01_out_filtered, (rho11 + rho00) / 2, rho_fixed)
    r10_final <- c(r10_out_filtered, (rho11 + rho00) / 2, rho_fixed)
    
    # rho_root_values_out est utilisé pour le rapport final
    # Il doit contenir les valeurs réelles de r01 issues de la racine (s'il y en a)
    # puis la moyenne et la valeur fixe.
    rho_root_values_out <- c(r01_out_filtered, mean(cor_params[5:6]), rho_fixed) # cor_params[5:6] sont rho11 et rho00
    
  } else { # cor_structure == 1
    r01_final <- cor_params[3] # rho_M1M2
    r10_final <- cor_params[3]
  }
  
  return(list(r01 = r01_final, r10 = r10_final, rho_root_values = rho_root_values_out))
}

#### `calculate_conditional_effects`

#' @title Calcule les effets directs et indirects conditionnels
#'
#' @description
#' Calcule les effets direct (DE) et indirect (IE) conditionnels pour un traitement
#' et un ensemble de médiateurs, en tenant compte des covariables et de l'interaction
#' selon différents scénarios de corrélation.
#'
#' @param alpha List de `data.frame`s avec les coefficients alpha (pour chaque médiateur).
#' @param beta Data.frame avec les coefficients beta du modèle de l'outcome.
#' @param treat Nom de la variable traitement.
#' @param mediators Vecteur de noms des médiateurs.
#' @param intmed_cov Vecteur de noms des covariables du médiateur d'intérêt.
#' @param sed_cov Vecteur de noms des covariables du second médiateur.
#' @param inter Booléen, TRUE si interaction est prise en compte.
#' @param cor_params_vec Vecteur numérique des coefficients de corrélation bruts.
#' @param rho_values Vecteur numérique des valeurs de corrélation $r_{01}$ à considérer.
#' @param data Data.frame contenant les variables utilisées dans les calculs.
#' @param cor_structure Entier indiquant le type de corrélation (3 = non constante, 1 = constante).
#'
#' @return Liste contenant :
#'   \item{DE_calculated}{Effets directs moyens calculés.}
#'   \item{IE_calculated}{Effets indirects moyens calculés.}
#' @keywords internal
calculate_conditional_effects <- function(alpha, beta, treat, mediators, intmed_cov, sed_cov,
                                          inter, cor_params_vec, rho_values, data, cor_structure) {
  
  # Extraire les coefficients alpha
  # Médiateur 1
  a01 <- alpha[[mediators[1]]]["(Intercept)", "value"]
  a11 <- alpha[[mediators[1]]][treat, "value"]
  a21_vals <- if (!is.null(intmed_cov)) alpha[[mediators[1]]][intmed_cov, "value"] else NULL
  
  # Médiateur 2
  a02 <- alpha[[mediators[2]]]["(Intercept)", "value"]
  a12 <- alpha[[mediators[2]]][treat, "value"]
  a22_vals <- if (!is.null(sed_cov)) alpha[[mediators[2]]][sed_cov, "value"] else NULL
  
  # Extraire les coefficients beta
  b0 <- beta["(Intercept)", "value"]
  b1 <- beta[treat, "value"]
  b21 <- beta[mediators[1], "value"]
  b22 <- beta[mediators[2], "value"]
  
  # Extraire les coefficients d'interaction beta si 'inter' est TRUE
  b_inter_terms <- setNames(rep(0, 4), c(paste0(treat, ":", mediators[1]),
                                         paste0(treat, ":", mediators[2]),
                                         paste0(mediators[1], ":", mediators[2]),
                                         paste0(treat, ":", mediators[1], ":", mediators[2])))
  if (inter) {
    for (name in names(b_inter_terms)) {
      if (name %in% rownames(beta)) {
        b_inter_terms[name] <- beta[name, "value"]
      }
    }
  }
  
  DE_k_list <- list()
  IE_k_list <- list()
  
  for (k in seq_along(rho_values)) {
    current_rho <- rho_values[k]
    
    # Termes qui peuvent dépendre des covariables
    # Terme M1_0 (E[M1(0)|C])
    term_m1_c0 <- a01
    if (!is.null(intmed_cov) && !is.null(a21_vals)) {
      term_m1_c0 <- term_m1_c0 + as.matrix(data[, intmed_cov]) %*% a21_vals
    }
    
    # Terme M2_1 (E[M2(1)|C])
    term_m2_c1 <- a02 + a12
    if (!is.null(sed_cov) && !is.null(a22_vals)) {
      term_m2_c1 <- term_m2_c1 + as.matrix(data[, sed_cov]) %*% a22_vals
    }
    
    # Calcul des composantes de l'effet direct (DE)
    if (cor_structure == 3) {
      # cor_params_vec: (s11,s10,s21,s20,rho11,rho00)
      s11 <- cor_params_vec[1]; s10 <- cor_params_vec[2]
      s21 <- cor_params_vec[3]; s20 <- cor_params_vec[4]
      rho11 <- cor_params_vec[5]; rho00 <- cor_params_vec[6]
      
      # Composantes du DE
      termDE1 <- b1
      termDE2 <- a12 * b22
      termDE3 <- term_m1_c0 * b_inter_terms[paste0(treat, ":", mediators[1])]
      termDE4 <- term_m2_c1 * b_inter_terms[paste0(treat, ":", mediators[2])]
      
      termDE5 <- (a12 * term_m1_c0 + s10 * s21 * current_rho - s10 * s20 * rho00) * b_inter_terms[paste0(mediators[1], ":", mediators[2])]
      termDE6 <- (term_m1_c0 * term_m2_c1 + s10 * s21 * current_rho) * b_inter_terms[paste0(treat, ":", mediators[1], ":", mediators[2])]
      
      de_mean <- mean(termDE1 + termDE2 + termDE3 + termDE4 + termDE5 + termDE6, na.rm = TRUE)
      
      # Calcul des composantes de l'effet indirect (IE)
      termIE1 <- a11 * (b21 + b_inter_terms[paste0(treat, ":", mediators[1])])
      termIE2 <- (a11 * term_m2_c1 + s11 * s20 * rho11 - s10 * s21 * current_rho) * (b_inter_terms[paste0(mediators[1], ":", mediators[2])] + b_inter_terms[paste0(treat, ":", mediators[1], ":", mediators[2])])
      
      ie_mean <- mean(termIE1 + termIE2, na.rm = TRUE)
      
    } else { # cor_structure == 1
      # cor_params_vec: (sigma1, sigma2, rho)
      s1 <- cor_params_vec[1]; s2 <- cor_params_vec[2]
      rho_val <- cor_params_vec[3] # C'est rho_M1M2, équivalent à current_rho dans ce cas
      
      # Composantes du DE
      termDE1 <- b1
      termDE2 <- a12 * b22
      termDE3 <- term_m1_c0 * b_inter_terms[paste0(treat, ":", mediators[1])]
      termDE4 <- term_m2_c1 * b_inter_terms[paste0(treat, ":", mediators[2])]
      termDE5 <- (a12 * term_m1_c0) * b_inter_terms[paste0(mediators[1], ":", mediators[2])]
      termDE6 <- (term_m1_c0 * term_m2_c1 + s1 * s2 * current_rho) * b_inter_terms[paste0(treat, ":", mediators[1], ":", mediators[2])]
      
      de_mean <- mean(termDE1 + termDE2 + termDE3 + termDE4 + termDE5 + termDE6, na.rm = TRUE)
      
      # Composantes de l'IE
      termIE1 <- a11 * (b21 + b_inter_terms[paste0(treat, ":", mediators[1])])
      termIE2 <- a11 * term_m2_c1 * (b_inter_terms[paste0(mediators[1], ":", mediators[2])] + b_inter_terms[paste0(treat, ":", mediators[1], ":", mediators[2])])
      
      ie_mean <- mean(termIE1 + termIE2, na.rm = TRUE)
    }
    
    DE_k_list[[k]] <- de_mean
    IE_k_list[[k]] <- ie_mean
  }
  
  return(list(DE_calculated = unlist(DE_k_list), IE_calculated = unlist(IE_k_list)))
}
