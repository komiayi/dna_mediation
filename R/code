#### `generate_model_formulas`


#' @title Génère les formules des modèles pour la médiation causale
#'
#' @description
#' Cette fonction construit les formules R pour les modèles des médiateurs et
#' de la variable de réponse, en tenant compte des covariables et des interactions.
#'
#' @param treat Nom de la variable de traitement.
#' @param mediators Vecteur de noms des variables médiatrices (le premier est le médiateur d'intérêt).
#' @param intmed Nom du médiateur d'intérêt.
#' @param sedmed Nom du second médiateur.
#' @param outcome Nom de la variable de réponse.
#' @param intmed_cov Vecteur de noms des covariables pour le médiateur d'intérêt.
#' @param sed_cov Vecteur de noms des covariables pour le second médiateur.
#' @param out_cov Vecteur de noms des covariables pour la variable de réponse.
#' @param inter_treat_cov Logique : Si `TRUE`, interaction traitement-covariables dans les modèles des médiateurs.
#' @param inter Logique : Si `TRUE`, interactions traitement-médiateurs dans le modèle de réponse.
#' @param formula_outcome_custom Formule personnalisée pour le modèle de réponse.
#'
#' @return Une liste contenant les objets `formula` pour `formula_m1`, `formula_m2`, et `formula_outcome`.
#' @keywords internal
generate_model_formulas <- function(treat, mediators, intmed, sedmed, outcome,
                                    intmed_cov, sed_cov, out_cov,
                                    inter_treat_cov, inter, formula_outcome_custom) {
  
  # Formule pour le premier médiateur (intmed)
  if (is.null(intmed_cov)) {
    rhs_m1 <- treat
  } else if (isTRUE(inter_treat_cov)) {
    rhs_m1 <- paste(treat, paste(intmed_cov, collapse = "*"), sep = "*")
  } else {
    rhs_m1 <- paste(c(treat, intmed_cov), collapse = " + ")
  }
  formula_m1 <- as.formula(paste(intmed, rhs_m1, sep = " ~ "))
  
  # Formule pour le second médiateur (sedmed)
  if (is.null(sed_cov)) {
    rhs_m2 <- treat
  } else if (isTRUE(inter_treat_cov)) {
    rhs_m2 <- paste(treat, paste(sed_cov, collapse = "*"), sep = "*")
  } else {
    rhs_m2 <- paste(c(treat, sed_cov), collapse = " + ")
  }
  formula_m2 <- as.formula(paste(sedmed, rhs_m2, sep = " ~ "))
  
  # Formule pour la variable de réponse (outcome)
  if (isTRUE(inter)) {
    if (is.null(formula_outcome_custom)) {
      # Génération d'une formule par défaut avec interactions
      interaction_terms <- c(
        paste0(treat, ":", mediators[1]),
        paste0(treat, ":", mediators[2]),
        paste0(mediators[1], ":", mediators[2]),
        # Inclure interaction triple si pertinent pour le modèle
        paste0(treat, ":", mediators[1], ":", mediators[2])
      )
      all_rhs_terms <- c(treat, mediators, out_cov, interaction_terms)
      rhs_outcome <- paste(all_rhs_terms, collapse = " + ")
      formula_outcome <- as.formula(paste(outcome, rhs_outcome, sep = " ~ "))
    } else {
      formula_outcome <- as.formula(paste(outcome, deparse(formula_outcome_custom[[3]]), sep = " ~ "))
    }
  } else {
    all_rhs_terms <- c(treat, mediators, out_cov)
    rhs_outcome <- paste(all_rhs_terms, collapse = " + ")
    formula_outcome <- as.formula(paste(outcome, rhs_outcome, sep = " ~ "))
  }
  
  return(list(
    formula_m1 = formula_m1,
    formula_m2 = formula_m2,
    formula_outcome = formula_outcome
  ))
}


#### `estimate_correlation_parameters`

#Cette fonction estime les variances et covariances/corrélations des résidus des médiateurs.

#' @title Estime les paramètres de corrélation des résidus des médiateurs (méthode analytique)
#'
#' @description
#' Calcule les écarts-types et les corrélations des résidus des modèles de médiateurs
#' en utilisant des expressions analytiques (basées sur les résidus de `lm`).
#'
#' @param residuals_m1 Vecteur des résidus du premier modèle de médiateur.
#' @param residuals_m2 Vecteur des résidus du second modèle de médiateur.
#' @param data Le jeu de données original.
#' @param treat Nom de la variable de traitement.
#' @param cor_structure Entier : 1 pour corrélation constante, 3 pour corrélations distinctes.
#'
#' @return Une liste avec le vecteur `cor_coefs` (paramètres de corrélation).
#' @importFrom stats sd cor
#' @keywords internal
estimate_correlation_parameters_analytic <- function(residuals_m1, residuals_m2, data, treat, cor_structure) {
  cor_coefs <- NULL
  
  if (cor_structure == 1) {
    # Corrélation constante
    sigma1 <- sd(residuals_m1)
    sigma2 <- sd(residuals_m2)
    rho <- cor(residuals_m1, residuals_m2)
    cor_coefs <- c(sigma1, sigma2, rho)
  } else { # cor_structure == 3
    # Corrélations distinctes par niveau de traitement
    # S'assurer que les résidus correspondent aux sous-groupes de données
    res_m1_t1 <- residuals_m1[data[[treat]] == 1]
    res_m2_t1 <- residuals_m2[data[[treat]] == 1]
    res_m1_t0 <- residuals_m1[data[[treat]] == 0]
    res_m2_t0 <- residuals_m2[data[[treat]] == 0]
    
    sigma1_t1 <- sd(res_m1_t1)
    sigma1_t0 <- sd(res_m1_t0)
    sigma2_t1 <- sd(res_m2_t1)
    sigma2_t0 <- sd(res_m2_t0)
    
    rho_t1 <- cor(res_m1_t1, res_m2_t1)
    rho_t0 <- cor(res_m1_t0, res_m2_t0)
    
    cor_coefs <- c(sigma1_t1, sigma1_t0, sigma2_t1, sigma2_t0, rho_t1, rho_t0)
  }
  return(list(cor_coefs = cor_coefs))
}


#### ``Loglik.med`

#' @title Fonction de log-vraisemblance négative pour les modèles de médiateurs
#'
#' @description
#' Calcule la log-vraisemblance négative pour l'estimation des paramètres des
#' deux modèles de médiateurs, en supposant une distribution normale multivariée
#' pour les résidus. Utilisée avec `optim`.
#'
#' @param par Vecteur des paramètres à optimiser (coefficients de régression et paramètres de corrélation).
#' @param q1 Nombre de coefficients dans le modèle du premier médiateur.
#' @param q2 Nombre de coefficients dans le modèle du second médiateur.
#' @param treat Nom de la variable de traitement.
#' @param mediators Vecteur de noms des variables médiatrices.
#' @param formula_m1 Formule du modèle du premier médiateur.
#' @param formula_m2 Formule du modèle du second médiateur.
#' @param data Jeu de données.
#' @param cor_structure Entier : 1 pour corrélation constante, 3 pour corrélation non constante.
#'
#' @return La valeur de la log-vraisemblance négative.
#' @importFrom mvtnorm dmvnorm
#' @importFrom stats model.matrix
#' @keywords internal
Loglik.med <-function(par, q1,q2, treat,mediators, formula_m1,formula_m2, data = NULL, cor_structure= 1){
  
  # Extraire la partie droite des formules
  rhs_m1 <- paste0("~", deparse(formula_m1[[3]]))
  rhs_m2 <- paste0("~", deparse(formula_m2[[3]]))
  
  # Création des matrices de design
  D11 <- model.matrix(as.formula(rhs_m1), data)
  D22 <- model.matrix(as.formula(rhs_m2), data)
  
  if(cor_structure==1){
    alpha11 <- par[1:q1]
    alpha22 <- par[(q1+1):(q1+q2)]
    sigma_11 <- par[q1+q2+1]
    sigma_22 <- par[q1+q2+2]
    Rhoo <- par[q1+q2+3]
    
    # Calculs linéaires
    A11 <- D11 %*% alpha11
    A22 <- D22 %*% alpha22
    
    Sigma <- matrix(c(sigma_11^2, Rhoo*sigma_11*sigma_22, Rhoo*sigma_11*sigma_22, sigma_22^2), 2, 2)
    # Assurer que Sigma est définie positive
    if (any(eigen(Sigma)$values <= 0)) {
      return(1e10) # Retourne une très grande valeur pour pénaliser les matrices non valides
    }
    f.med <- dmvnorm(data[,mediators]- cbind(A11,A22), mean = rep(0,nrow(Sigma)) , sigma = Sigma, log = TRUE)
  }else{
    alpha11 <- par[1:q1]
    alpha22 <- par[(q1+1):(q1+q2)]
    sigma11 <- par[q1+q2+1]
    sigma10 <- par[q1+q2+2]
    sigma21 <- par[q1+q2+3]
    sigma20 <- par[q1+q2+4]
    Rhoo11 <- par[q1+q2+5]
    Rhoo00 <- par[q1+q2+6]
    
    # Validation des bornes pour les corrélations
    if (any(abs(c(Rhoo11, Rhoo00)) >= 1)) {
      return(1e10) # Pénalise les valeurs de corrélation hors bornes
    }
    
    # Calculs linéaires
    A11 <- D11 %*% alpha11
    A22 <- D22 %*% alpha22
    
    # Calculs pour la log-vraisemblance par observation
    A42 <- ifelse(data[,treat]==1, sigma11, sigma10)
    A43 <- ifelse(data[,treat]==1, sigma21, sigma20)
    A44 <- ifelse(data[,treat]==1, Rhoo11, Rhoo00)
    
    # Éviter les divisions par zéro ou les log de zéro/négatif
    if (any(A42 <= 0) || any(A43 <= 0) || any(1-(A44)**2 <= 0)) {
      return(1e10)
    }
    
    Am1 <- (data[,mediators[1]]-A11)/A42
    Am2 <- (data[,mediators[-1]]-A22)/A43
    A40 <- (Am1)**2 + (Am2)**2 -2*A44*(Am1)*(Am2)
    A41 <- A40/(1-(A44)**2)
    
    f.med <- -log(2*pi) - log(A42) - log(A43) - 0.5*log(1-(A44)^2) -0.5*A41
  }
  # Gérer les NaNs ou Inf résultant des calculs
  if (any(!is.finite(f.med))) {
    return(1e10)
  }
  return(-sum(f.med))
}

#### `estimate_mediator_params_optim`

#' @title Estime les paramètres des modèles de médiateurs (méthode optimisée)
#'
#' @description
#' Estime les coefficients et les paramètres de corrélation des modèles de médiateurs
#' en minimisant la log-vraisemblance négative via `optim`.
#'
#' @param par Vecteur initial des paramètres pour l'optimisation.
#' @param q1 Nombre de coefficients dans le modèle du premier médiateur.
#' @param q2 Nombre de coefficients dans le modèle du second médiateur.
#' @param treat Nom de la variable de traitement.
#' @param mediators Vecteur de noms des variables médiatrices.
#' @param formula_m1 Formule du modèle du premier médiateur.
#' @param formula_m2 Formule du modèle du second médiateur.
#' @param data Jeu de données.
#' @param cor_structure Entier : 1 pour corrélation constante, 3 pour corrélation non constante.
#'
#' @return Une liste avec les coefficients estimés `Cint`, `Csed`, `Ccor`, et la hessienne `Chess`.
#' @importFrom stats optim
#' @keywords internal
estimate_mediator_params_optim <- function(par, q1,q2, treat,mediators,formula_m1,formula_m2,
                                           data = NULL, cor_structure= 1){
  coef.intmed <- coef.sedmed <- NULL
  coes <- NULL
  par.med <- par
  
  if(cor_structure==1){
    # Bornes : coefficients [-Inf, Inf], std dev [0, Inf], rho [-1, 1]
    lower_bounds <- c(rep(-Inf, q1+q2), rep(1e-6,2), -0.99999) # std dev > 0 pour stabilité log
    upper_bounds <- c(rep(Inf, q1+q2), rep(Inf,2), 0.99999)
  }else{
    # Bornes : coefficients [-Inf, Inf], std dev [0, Inf], rho [-1, 1]
    lower_bounds <- c(rep(-Inf, q1+q2), rep(1e-6,4), rep(-0.99999,2))
    upper_bounds <- c(rep(Inf, q1+q2), rep(Inf,4), rep(0.99999,2))
  }
  
  # Contrôle pour optim: 'ndeps' doit avoir la même longueur que 'par'
  # 'parscale' est utile pour aider l'optimisation mais peut être problématique si 0
  # Une approche simple est de l'initialiser avec par.med et de s'assurer qu'aucun élément n'est zéro
  parscale_val <- par.med
  parscale_val[parscale_val == 0] <- 1 # Remplace les zéros par 1 pour éviter les problèmes
  
  coes <- optim(par = par.med, fn = Loglik.med, data = data, q1=q1, q2=q2,
                treat = treat,mediators = mediators, formula_m1 =  formula_m1,
                formula_m2 = formula_m2 , method = "L-BFGS-B",
                lower= lower_bounds, upper= upper_bounds,
                control = list(ndeps=rep(1e-4,length(par.med)), maxit=1e4, parscale = parscale_val),
                hessian = TRUE
  )
  if (coes$convergence > 0L){
    warning(paste("L'optimisation n'a pas convergé :", coes$message))
  }
  
  coef.intmed <- as.vector(coes$par[1:q1])
  coef.sedmed <- as.vector(coes$par[(q1+1):(q1+q2)])
  cor_coef <- as.vector(coes$par[-c(1:(q1+q2))])
  
  return(list(Cint = coef.intmed, Csed=coef.sedmed, Ccor=cor_coef, Chess = coes$hessian))
}


